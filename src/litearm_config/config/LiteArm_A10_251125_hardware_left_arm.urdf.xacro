<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="LiteArm_A10_251125_left_arm">

  <!-- Arguments -->
  <xacro:arg name="config_file" default=""/>
  <xacro:arg name="control_mode" default="position_velocity"/>
  <xacro:arg name="initial_positions_file" default="$(find litearm_config)/config/initial_positions.yaml"/>

  <!-- Import robot description (links and joints) -->
  <xacro:include filename="$(find litearm_a10_251125)/urdf/LiteArm_A10_251125.urdf" />

  <!-- Import hardware ros2_control configuration -->
  <xacro:include filename="$(find litearm_config)/config/LiteArm_A10_251125_hardware_left_arm.ros2_control.xacro"/>

  <!-- Instantiate ros2_control hardware interface for left arm only -->
  <xacro:litearm_left_arm_hardware_ros2_control
    name="LiteArmLeftArmHardware"
    config_file="$(arg config_file)"
    control_mode="$(arg control_mode)"/>

</robot>
